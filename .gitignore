# Entornos virtuales
venv/
env/
.venv/

# Variables de entorno y secretos
.env
.env.*
!.env.example

# Caché y archivos compilados de Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Logs y bases de datos locales (por si haces pruebas con SQLite)
*.log
*.sqlite3

# Configuraciones de editores de código (VS Code, PyCharm, etc.)
.vscode/
.idea/
*.swp

# Herramientas de testing y cobertura
.pytest_cache/
htmlcov/
.coverage